actor "Guest" as GUEST #ff8844
actor "Player" as PLAYER #44aaff
actor "Admin" as ADMIN #ff4444
actor "System" as SYSTEM #44ff88
actor "AllianceLeader" as ALLDR #ffaa44
actor "Moderator" as MOD #ff66aa

