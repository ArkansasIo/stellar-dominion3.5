@startuml
' UseCase-Diagram.puml — Universe Civilization: Empires at War
skinparam backgroundColor #0a0a1a
skinparam usecase {
  BackgroundColor #1a3a2a
  BorderColor #4aff9e
  FontColor #e0ffe0
}
skinparam actor {
  BorderColor #ff9e4a
  FontColor #ffe0b0
}
skinparam arrow {
  Color #c0c0ff
}

left to right direction

