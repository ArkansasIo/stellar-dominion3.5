' ============================================================
' DEPENDENCY RELATIONSHIPS
' ============================================================

' Client internal
PAGES --> COMP : composes
PAGES --> HOOKS : uses
PAGES --> STORE : dispatches
PAGES --> SRV : calls
PAGES --> CUTIL : imports
COMP --> STORE : reads/selects
COMP --> HOOKS : uses
HOOKS --> SRV : invokes
HOOKS --> CUTIL : imports
SRV --> CUTIL : imports
STORE --> SRV : async thunks

' Server internal
ROUTES --> MW : middleware chain
ROUTES --> SVC : delegates
SVC --> GAME : game logic
SVC --> MODELS : ORM
SVC --> REPO : data access
SVC --> WS : push updates
SVC --> SUTIL : helpers
GAME --> MODELS : reads/writes
GAME --> REPO : persistence
WS --> SVC : callbacks
CONFIG --> SUTIL : env helpers

' Cross-package (server → shared)
ROUTES -.-> SHARED : import types
SVC -.-> SHARED : import types
GAME -.-> SHARED : import config
MODELS -.-> SHARED : import enums
REPO -.-> SHARED : import types
MW -.-> SHARED : import constants

' Cross-package (client → shared)
PAGES -.-> SHARED : import types
COMP -.-> SHARED : import enums
HOOKS -.-> SHARED : import config
SRV -.-> SHARED : import types
STORE -.-> SHARED : import types
CUTIL -.-> SHARED : import formulas

' Database
DB -.-> SERVER : migration target
MIG --> SCHEMA : executes
SEEDS --> MIG : post-migration
DBCFG --> SERVER : config

' Tests
TESTS -.-> SERVER : tests against
TESTS -.-> CLIENT : tests against
TESTS -.-> DB : seeds for test

@enduml
